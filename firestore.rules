rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
      match /receipts/{receiptId} {
        allow read, write: if isOwner(userId);
      }
      match /ocrJobs/{jobId} {
        allow read, write: if isOwner(userId);
      }
      match /splitSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
      match /friends/{friendUserId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /splitSessions/{sessionId} {
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isSignedIn() &&
        (resource.data.ownerUserId == request.auth.uid ||
         request.auth.uid in resource.data.memberUserIds);
      allow update: if isSignedIn() &&
        (resource.data.ownerUserId == request.auth.uid ||
         request.auth.uid in resource.data.memberUserIds);
      allow delete: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
    }

    match /splitInvites/{inviteCode} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.recipientId is string
        && request.resource.data.senderId != request.resource.data.recipientId
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.auth.uid in request.resource.data.members
        && request.resource.data.recipientId in request.resource.data.members;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.members
        && request.resource.data.members == resource.data.members
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.recipientId == resource.data.recipientId;
      allow delete: if false;
    }
  }
}
