rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /receipts/{receiptId} {
        allow read, write: if isOwner(userId);
      }
      match /ocrJobs/{jobId} {
        allow read, write: if isOwner(userId);
      }
      match /splitSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /splitSessions/{sessionId} {
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow read: if isSignedIn() &&
        (resource.data.ownerUserId == request.auth.uid ||
         request.auth.uid in resource.data.memberUserIds);
      allow update: if isSignedIn() &&
        (resource.data.ownerUserId == request.auth.uid ||
         request.auth.uid in resource.data.memberUserIds);
      allow delete: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
    }

    match /splitInvites/{inviteCode} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
    }
  }
}
